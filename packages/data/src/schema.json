{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AISC SimEngine Data — Core Reference Table",
  "type": "object",
  "required": ["values"],
  "properties": {
    "values": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["value", "unit", "source"],
        "properties": {
          "value": { "type": "number" },
          "unit": { "type": "string" },
          "symbol": { "type": "string" },
          "name": { "type": "string" },
          "source": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
